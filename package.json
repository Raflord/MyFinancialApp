{
  "name": "MyFinancialApp",
  "version": "0.0.1",
  "description": "MyFinancialApp is an app for money management designed specific for me and my experience",
  "author": "Rafael Wrobel",
  "license": "MIT",
  "homepage": "https://github.com/raflord/MyFinancialApp",
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "./client",
    "./server",
    "./shared"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:client": "turbo dev --filter=@client",
    "dev:server": "turbo dev --filter=@server",
    "build": "turbo build",
    "build:client": "turbo build --filter=@client",
    "build:server": "turbo build --filter=@server",
    "lint": "biome lint .",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "postinstall": "turbo build --filter=@shared --filter=@server --filter=@client",
    "format": "biome format . --write"
  },
  "keywords": [
    "bun",
    "elysia",
    "react",
    "vite",
    "monorepo",
    "turbo",
    "drizzle",
    "better-auth"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "bun-types": "^1.3.13",
    "turbo": "^2.9.6"
  },
  "peerDependencies": {
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@tanstack/react-form": "^1.29.1",
    "better-auth": "^1.6.9",
    "elysia": "^1.4.28",
    "motion": "^12.38.0"
  }
}
